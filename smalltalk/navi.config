# =============================================================
# NAVI :: navi.config
# =============================================================
# Descomenta UN solo bloque y comenta el resto.
# =============================================================


# --- PROVEEDOR ACTIVO ---
PROVIDER=llamacpp-local
LLM_URL=http://HOST:11434/v1/chat/completions
MODEL=qwen3
API_KEY=


# =============================================================
# LOCAL — llama.cpp (puerto 11434 en tu caso)
#
# Modelo actual (3B, rapido):
# .\llama-server.exe -m E:\qwen2.5-3b-instruct-q3_k_m.gguf \
#   --host 0.0.0.0 --port 11434 -ngl 999 -c 8192 -n 1024 \
#   -b 512 -ub 128 -t 4 -tb 4 --mlock
# 
# ./llama-server -m ../qwen2.5-3b-instruct-q3_k_m.gguf --host 0.0.0.0 --port 11434
# 
# Para cambiar a 7B (mas capaz, mas lento):
# .\llama-server.exe -m E:\qwen2.5-7b-instruct-q4_k_m-00001-of-00002.gguf \
#   --host 0.0.0.0 --port 11434 -ngl 999 -c 8192 -n 1024 \
#   -b 512 -ub 128 -t 4 -tb 4 --mlock
# =============================================================
# PROVIDER=llamacpp
# LLM_URL=http://host.docker.internal:11434/v1/chat/completions
# MODEL=qwen2.5-7b-instruct-q4_k_m-00001-of-00002.gguf
# API_KEY=


# =============================================================
# LOCAL — llama.cpp (puerto estandar 8080)
# .\llama-server.exe -m E:\tu_modelo.gguf --port 8080
# =============================================================
# PROVIDER=llamacpp
# LLM_URL=http://host.docker.internal:8080/v1/chat/completions
# MODEL=qwen2.5-3b-instruct-q3_k_m.gguf
# API_KEY=


# =============================================================
# LOCAL — Ollama
# ollama run qwen2.5:7b
# =============================================================
# PROVIDER=ollama
# LLM_URL=http://host.docker.internal:11434/v1/chat/completions
# MODEL=qwen2.5:7b
# API_KEY=


# =============================================================
# LOCAL — LM Studio
# GUI -> Developer -> Start Server (puerto 1234)
# =============================================================
# PROVIDER=lmstudio
# LLM_URL=http://host.docker.internal:1234/v1/chat/completions
# MODEL=qwen2.5-7b-instruct
# API_KEY=lm-studio


# =============================================================
# CLOUD — Groq (gratis, sin tarjeta)
# https://console.groq.com -> API Keys
# =============================================================
# PROVIDER=groq
# LLM_URL=https://api.groq.com/openai/v1/chat/completions
# MODEL=llama-3.3-70b-versatile
# API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXX


# =============================================================
# CLOUD — Google Gemini (gratis, 1500 req/dia)
# https://aistudio.google.com -> Get API key
# =============================================================
# PROVIDER=gemini
# LLM_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
# MODEL=gemini-2.5-flash
# API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXX


# =============================================================
# CLOUD — OpenRouter (35+ modelos gratis con sufijo :free)
# https://openrouter.ai -> Keys
# =============================================================
# PROVIDER=openrouter
# LLM_URL=https://openrouter.ai/api/v1/chat/completions
# MODEL=meta-llama/llama-3.3-70b-instruct:free
# API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXX


# =============================================================
# CLOUD — Mistral (gratis, 1B tokens/mes)
# https://console.mistral.ai -> API Keys
# =============================================================
# PROVIDER=mistral
# LLM_URL=https://api.mistral.ai/v1/chat/completions
# MODEL=mistral-small-latest
# API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# =============================================================
# CLOUD — Cerebras (gratis, 1M tokens/dia, muy rapido)
# https://cloud.cerebras.ai -> API Keys
# =============================================================
# PROVIDER=cerebras
# LLM_URL=https://api.cerebras.ai/v1/chat/completions
# MODEL=llama-3.3-70b
# API_KEY=csk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# =============================================================
# CLOUD — NVIDIA NIM (gratis, 40 RPM)
# https://build.nvidia.com -> Get API Key
# =============================================================
# PROVIDER=nim
# LLM_URL=https://integrate.api.nvidia.com/v1/chat/completions
# MODEL=meta/llama-3.3-70b-instruct
# API_KEY=nvapi-XXXXXXXXXXXXXXXXXXXXXXXX


# =============================================================
# CLOUD — Anthropic Claude
# https://console.anthropic.com -> API Keys
